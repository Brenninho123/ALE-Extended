<?xml version="1.0" encoding="utf-8"?>
<project xmlns="http://lime.openfl.org/project/1.0.4">

	<!-- ================= APP ================= -->
	<app title="Friday Night Funkin': ALE Extended"
		 file="ALEExtended"
		 packageName="com.brenninho.aleextended"
		 main="core.Main"
		 version="0.1.0"
		 company="Brenninho"/>

	<set name="APP_ID" value="0x0100f6c013bbc000"/>
	<set name="SWF_VERSION" value="11.8"/>

	<app preloader="flixel.system.FlxPreloader"/>

	<!-- ================= DEFINES ================= -->

	<!-- Core -->
	<define name="LUA_ALLOWED" if="cpp"/>
	<define name="HSCRIPT_ALLOWED"/>
	<define name="MODS_ALLOWED"/>

	<!-- Systems -->
	<define name="DISCORD_ALLOWED" if="desktop cpp"/>
	<define name="VIDEOS_ALLOWED" if="windows || linux || android"/>
	<define name="WINDOWS_API" if="windows cpp"/>
	<define name="MOBILE_API" if="mobile"/>

	<!-- Debug / Crash -->
	<define name="CRASH_HANDLER"/>
	<define name="TRACY_ALLOWED" if="cpp windows"/>
	<define name="HXCPP_DEBUGGER" if="debug"/>

	<!-- Optimization -->
	<define name="COMPILE_ALL_CLASSES" unless="debug"/>
	<define name="NO_DYNAMIC_ASSETS" unless="debug"/>

	<!-- Engine -->
	<define name="WM_ENGINE" value="ALE_PSYCH"/>

	<!-- ================= WINDOW ================= -->

	<window width="1280" height="720"
			fps="120"
			background="#000000"
			hardware="true"
			vsync="false"
			antialiasing="4"/>

	<window if="desktop"
			orientation="landscape"
			fullscreen="false"
			resizable="true"/>

	<window if="mobile"
			orientation="landscape"
			fullscreen="true"
			resizable="false"
			allow-shaders="true"
			require-shaders="true"/>

	<!-- ================= PATHS ================= -->

	<set name="BUILD_DIR" value="export/debug" if="debug"/>
	<set name="BUILD_DIR" value="export/release" unless="debug"/>

	<source path="source"/>

	<assets path="assets" embed="false"/>
	<assets path="mods" embed="false"/>
	<assets path="defines" embed="false"/>

	<!-- ================= LIBS ================= -->

	<haxelib name="flixel"/>
	<haxelib name="flixel-ui"/>
	<haxelib name="flixel-addons"/>
	<haxelib name="flixel-animate"/>

	<haxelib name="tink_core"/>
	<haxelib name="jsonmod"/>

	<haxelib name="grig.audio"/>
	<haxelib name="funkin.vis"/>

	<haxelib name="ale-ui"/>
	<haxelib name="flxsoundfilters"/>

	<!-- 3D / Advanced -->
	<haxelib name="away3d"/>
	<haxelib name="flixel-away3d"/>

	<!-- Video -->
	<haxelib name="hxvlc" if="VIDEOS_ALLOWED"/>

	<!-- Script -->
	<haxelib name="hxluajit" if="LUA_ALLOWED"/>
	<haxelib name="hxluajit-wrapper" if="LUA_ALLOWED"/>

	<haxelib name="rulescript" if="HSCRIPT_ALLOWED"/>
	<haxelib name="ale-rulescript-wrapper" if="HSCRIPT_ALLOWED"/>

	<!-- Discord -->
	<haxelib name="hxdiscord_rpc" if="DISCORD_ALLOWED"/>

	<!-- System -->
	<haxelib name="sl-windows-api"/>
	<haxelib name="window-modcharting"/>

	<!-- Mobile -->
	<haxelib name="extension-androidtools" if="android"/>
	<haxelib name="extension-orientation" if="mobile"/>

	<!-- ================= MACROS ================= -->

	<haxeflag name="--macro" value="core.macros.ImportsMacro.include()"/>

	<!-- ================= HAXE FLAGS ================= -->

	<haxeflag name="-dce" value="full"/>
	<haxedef name="no-deprecation-warnings"/>
	<haxedef name="lime_disable_assets_version"/>

	<!-- Performance -->
	<haxedef name="FLX_NO_DEBUG" unless="debug"/>
	<haxedef name="NAPE_RELEASE_BUILD" unless="debug"/>
	<haxedef name="HXCPP_GC_BIG_BLOCKS"/>
	<haxedef name="HXCPP_GC_GENERATIONAL"/>

	<!-- Debug -->
	<haxedef name="HXC_DEBUG_TRACE" if="debug"/>
	<haxedef name="HXCPP_STACK_TRACE" if="CRASH_HANDLER"/>
	<haxedef name="HXCPP_STACK_LINE" if="CRASH_HANDLER"/>

	<!-- Fixes -->
	<haxedef name="FLX_NO_FOCUS_LOST_SCREEN"/>

	<!-- ================= CPP ================= -->

	<section if="cpp">
		<setenv name="HAXEPATH" value="./"/>

		<haxedef name="HXCPP_CHECK_POINTER" if="CRASH_HANDLER"/>
		<haxedef name="HXCPP_CATCH_SEGV"/>
		<haxedef name="HXCPP_DEBUG_LINK"/>
	</section>

	<!-- ================= ICON ================= -->

	<icon path="art/icon16.png" size="16"/>
	<icon path="art/icon32.png" size="32"/>
	<icon path="art/icon64.png" size="64"/>
	<icon path="art/iconOG.png"/>

	<!-- ================= AUDIO ================= -->

	<section if="desktop">
		<assets path="alsoft.txt" rename="plugins/alsoft.ini" type="text" if="windows"/>
		<assets path="alsoft.txt" rename="plugins/alsoft.conf" type="text" unless="windows"/>
	</section>

	<!-- ================= ANDROID ================= -->

	<config type="android"
			gradle-version="8.10.2"
			gradle-plugin="8.8.0"
			ndkVersion="27.0"
			minimum-sdk-version="26"
			target-sdk-version="35"/>

	<config:android>
		<gradle-properties org.gradle.jvmargs="-Xmx4096m -XX:MaxMetaspaceSize=1024m"/>
	</config:android>

	<!-- Arquitetura (mais performance) -->
	<architecture name="arm64-v8a" if="android"/>

	<!-- Permissões modernas -->
	<config:android permission="android.permission.INTERNET"/>
	<config:android permission="android.permission.ACCESS_NETWORK_STATE"/>

	<!-- Storage moderno -->
	<config:android permission="android.permission.READ_MEDIA_IMAGES"/>
	<config:android permission="android.permission.READ_MEDIA_VIDEO"/>

	<!-- Legacy fallback -->
	<config:android permission="android.permission.READ_EXTERNAL_STORAGE"/>
	<config:android permission="android.permission.WRITE_EXTERNAL_STORAGE"/>

	<!-- APK install -->
	<config:android permission="android.permission.REQUEST_INSTALL_PACKAGES"/>

	<!-- Certificado -->
	<certificate path="key.keystore"
				 password="aleenginepass"
				 alias="ale-engine"
				 alias-password="aleenginepass"
				 if="android"/>

</project>
